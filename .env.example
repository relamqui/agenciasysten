# ============================================
# Kanban System — Variáveis de Ambiente
# ============================================

# Porta do servidor
PORT=3000

# PostgreSQL (Dados baseados na VPS / EasyPanel)
DB_USER=wpcrm_user
DB_PASSWORD=TROQUE_POR_SENHA_FORTE
DB_NAME=wpcrm
DB_HOST=teste_dashboard-db
DB_PORT=5432

# URL de Conexão Interna (VPS)
DATABASE_URL=postgres://wpcrm_user:TROQUE_POR_SENHA_FORTE@teste_dashboard-db:5432/wpcrm?sslmode=disable

# JWT Secret (gere um valor seguro para produção)
JWT_SECRET=mude-esta-chave-secreta-em-producao

# JWT Expiration
JWT_EXPIRES_IN=7d

# Node Environment
NODE_ENV=production
